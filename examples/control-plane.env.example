RUNNERLY_HOST=127.0.0.1
RUNNERLY_PORT=8787
RUNNERLY_DB_PATH=/opt/runnerly/data/runnerly.sqlite
RUNNERLY_ADMIN_TOKEN=replace-with-long-random-token
RUNNERLY_TOKEN_LOGIN_ENABLED=false
RUNNERLY_AGENT_TOKEN=replace-with-different-long-random-token
RUNNERLY_ALLOWED_REPOSITORIES=example-org/runnerly-lab:linux+arm64+build-worker,example-org/infra-deployments:linux+x64+micro+utility,example-org/security-scanner:linux+arm64+scanner

# Optional GitHub App integration.
RUNNERLY_GITHUB_OWNER=example-org
RUNNERLY_GITHUB_RUNNER_SCOPE=org
RUNNERLY_GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret
RUNNERLY_PUBLIC_WEBHOOK_URL=https://runnerly.example.com/api/github/webhook
RUNNERLY_GITHUB_APP_ID=
RUNNERLY_GITHUB_INSTALLATION_ID=
RUNNERLY_GITHUB_APP_PRIVATE_KEY_FILE=/etc/runnerly/github-app.private-key.pem
RUNNERLY_RUNNER_HEARTBEAT_ENABLED=true
RUNNERLY_RUNNER_HEARTBEAT_INTERVAL_MS=30000
RUNNERLY_RECONCILE_ENABLED=true
RUNNERLY_RECONCILE_INTERVAL_MS=300000
RUNNERLY_BACKUP_ENABLED=true
RUNNERLY_BACKUP_DIR=/opt/runnerly/data/backups
RUNNERLY_BACKUP_INTERVAL_MS=86400000
RUNNERLY_BACKUP_RETENTION_DAYS=14
RUNNERLY_BACKUP_MAX_FILES=14

# Optional GitHub OAuth admin login.
RUNNERLY_GITHUB_OAUTH_CLIENT_ID=
RUNNERLY_GITHUB_OAUTH_CLIENT_SECRET=
RUNNERLY_GITHUB_OAUTH_CALLBACK_URL=https://runnerly.example.com/api/auth/github/callback
RUNNERLY_GITHUB_ADMIN_ORG=example-org
RUNNERLY_GITHUB_ADMIN_TEAM_SLUGS=platform-admins
RUNNERLY_GITHUB_ALLOW_ORG_ADMINS=false
RUNNERLY_SESSION_SECRET=replace-with-long-random-session-secret
