[Unit]
Description=Runnerly agent
After=network-online.target runnerly-control-plane.service
Wants=network-online.target

[Service]
Type=simple
User=runnerly
Group=runnerly
WorkingDirectory=/opt/runnerly/app
Environment=RUNNERLY_CONTROL_PLANE_URL=http://127.0.0.1:8787
Environment=RUNNERLY_AGENT_CONFIG=/etc/runnerly/agent.json
EnvironmentFile=-/etc/runnerly/agent.env
ExecStart=/usr/bin/env node apps/agent/agent.mjs
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/runnerly

[Install]
WantedBy=multi-user.target
